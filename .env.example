# CONFIGURAÇÕES DE ACESSO - NEXUS CLOSER
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env.

CLICKUP_TOKEN=seu_token_aqui
CLICKUP_LIST_PIPELINE_ID=id_da_lista_pipeline
CLICKUP_LIST_CONTRATOS_ID=id_da_lista_contratos

# CONFIGURAÇÕES DO SISTEMA
TIMEOUT_CONEXAO=15
LOG_LEVEL=INFO

# CAMPOS CUSTOMIZADOS DO CLICKUP (UUIDs dos custom fields)
CLICKUP_FIELD_FATURAMENTO_BRUTO=uuid_do_campo
CLICKUP_FIELD_FATURAMENTO_LIQUIDO=uuid_do_campo
CLICKUP_FIELD_COMISSAO=uuid_do_campo
CLICKUP_FIELD_VALOR_ORCAMENTO=uuid_do_campo
CLICKUP_FIELD_ESTAGIO_LEAD=uuid_do_campo
CLICKUP_FIELD_PLANO=uuid_do_campo
CLICKUP_FIELD_OBJECAO=uuid_do_campo
CLICKUP_FIELD_WHATSAPP=uuid_do_campo
CLICKUP_FIELD_ETAPA_FOLLOWUP=uuid_do_campo

# BOTCONVERSA
BOTCONVERSA_API_KEY=sua_chave_aqui
BOTCONVERSA_BASE_URL=https://api.botconversa.com.br/api/v1
